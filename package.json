    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "rollup": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/virendra2902/smart-seo-lite"
  },
